<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Bootstrap demo</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
      rel="stylesheet"
      integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
      crossorigin="anonymous"
    />
    <link rel="stylesheet" href="/stylesheets/profile.css" />
  </head>
  <body>
    <div class="containerpers">
      <div class="cardpers">
        <div class="profile-picture">
          <img
            src="https://i.pinimg.com/1200x/5e/a9/8e/5ea98e932df9c794ab5ea242246201f0.jpg"
            alt="Profile Picture"
          />
        </div>
        <h2 class="name"><%=user.fullname%></h2>
        <h3 class="username">@<%=user.username%></h3>
        <p class="tagline">Some Tag Line</p>
        <p class="description">Some Description</p>
        <a href="/users" class="button">Logout</a>
      </div>
    </div>
    <div class="container">
      <div class="card" style="width: 18rem">
        <img
          src="https://images.unsplash.com/photo-1575903666082-42afed6270e3?w=600&auto=format&fit=crop&q=60&ixlib=rb-4.1.0&ixid=M3wxMjA3fDB8MHxzZWFyY2h8MTF8fHNreWZhbGx8ZW58MHx8MHx8fDA%3D"
          class="card-img-top"
          alt="..."
        />
        <div class="card-body">
          <h5 class="card-title">Card title</h5>
        </div>
      </div>
    </div>
  </body>
</html>
